mkdir prometheus
cd prometheus/

Step 1 — Install Helm
curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
helm version

Step 2 — Add Prometheus Stack Repo
helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
helm repo update

Step 3 — Install Prometheus Stack
helm install monitoring prometheus-community/kube-prometheus-stack

Step 4 — Check Pods
kubectl get pods

Step 5 - port-forward
kubectl port-forward --address 0.0.0.0 svc/monitoring-grafana 3000:8080

step-6
open ec2ip:3000
username : admin
password : 
kubectl get secret monitoring-grafana -o jsonpath="{.data.admin-password}" | base64 --decode ; echo

Delete username and password
kubectl delete secret monitoring-grafana

Create username and password
kubectl create secret generic monitoring-grafana \
  --from-literal=admin-user=admin \
  --from-literal=admin-password=admin123

delete pod grafana
kubectl delete pod -l app.kubernetes.io/name=grafana

Port-forward-permanent
nohup kubectl port-forward --address 0.0.0.0 svc/monitoring-grafana 3000:80 > grafana-port.log 2>&1 &
